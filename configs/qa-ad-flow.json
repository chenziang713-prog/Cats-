{
  "name": "qa-test-ad-loop",
  "window_title_contains": "ANG",
  "render_window_class": "RenderWindow",
  "cycle_interval_seconds": 600,
  "max_cycles": 1,
  "max_runtime_seconds": 7200,
  "minimum_ad_wait_seconds": 30,
  "confirm_timeout_seconds": 15,
  "close_poll_interval_seconds": 1,
  "close_timeout_seconds": 45,
  "post_close_wait_seconds": 2,
  "max_close_actions": 2,
  "ready_timeout_seconds": 60,
  "return_timeout_seconds": 30,
  "scale": {
    "min": 0.4,
    "max": 1.1,
    "step": 0.05
  },
  "states": {
    "ready": {
      "templates": [
        "templates/ad-entry.png"
      ],
      "threshold": 0.55,
      "match_mode": "color"
    },
    "confirm": {
      "templates": [
        "templates/ad-confirm-claim.png"
      ],
      "threshold": 0.70,
      "match_mode": "color"
    },
    "close_ad": {
      "templates": [
        "templates/ad-close-x.png",
        "templates/ad-close-text.png",
        "templates/ad-skip.png",
        "templates/ad-skip-light.png"
      ],
      "threshold": 0.60,
      "match_mode": "edge"
    },
    "returned": {
      "templates": [
        "templates/game-home-marker.png"
      ],
      "threshold": 0.55,
      "match_mode": "color"
    }
  }
}
